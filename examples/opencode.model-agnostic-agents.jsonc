{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "default_agent": "plan-orchestrator",
  "agent": {
    "plan-orchestrator": {
      "description": "Primary model-agnostic planning, coordination, and final-review agent. Use for architecture, hard problem solving, task decomposition, implementation plans, risk analysis, worker delegation, scope control, and final diff review.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "temperature": 0.1,
      "prompt": "{file:./prompts/plan-orchestrator.md}",
      "options": {
        "reasoningEffort": "high",
        "textVerbosity": "low",
        "reasoningSummary": "auto"
      },
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git add *": "ask",
          "git commit *": "ask"
        },
        "task": {
          "*": "deny",
          "explore": "allow",
          "scout": "allow",
          "fullstack-worker": "allow",
          "repair-worker": "allow",
          "docs-maintainer": "allow",
          "code-reviewer": "ask"
        },
        "webfetch": "ask",
        "websearch": "ask",
        "external_directory": "ask",
        "doom_loop": "ask"
      }
    },
    "scout": {
      "description": "Read-only external research agent. Use for version-sensitive documentation, SDK/API behavior, framework details, dependency edge cases, migration notes, browser/runtime behavior, and upstream-source investigation.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "temperature": 0.1,
      "prompt": "{file:./prompts/scout.md}",
      "options": {
        "reasoningEffort": "low",
        "textVerbosity": "low",
        "reasoningSummary": "auto",
        "include": ["reasoning.encrypted_content"]
      },
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "webfetch": "allow",
        "websearch": "ask",
        "external_directory": "ask",
        "doom_loop": "ask"
      }
    },
    "fullstack-worker": {
      "description": "Model-agnostic default implementation worker. Use for approved feature work, refactors, documentation changes, and coherent frontend/backend/full-stack edits when the plan is clear.",
      "mode": "subagent",
      "model": "openrouter/moonshotai/kimi-k2.6",
      "temperature": 0.2,
      "prompt": "{file:./prompts/fullstack-worker.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "allow",
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "npm run lint": "allow",
          "npm run lint *": "allow",
          "npm run typecheck": "allow",
          "npm run typecheck *": "allow",
          "npm run test": "allow",
          "npm run test *": "allow",
          "npm run test:coverage": "allow",
          "npm run test:coverage *": "allow",
          "npm run test:perf": "allow",
          "npm run test:perf *": "allow",
          "npm run css:audit": "allow",
          "npm run css:audit *": "allow",
          "npm run css:audit:strict": "allow",
          "npm run css:audit:strict *": "allow",
          "npm run build": "allow",
          "npm run build *": "allow",
          "npm run check": "allow",
          "npm run check *": "allow",
          "git add *": "ask",
          "git commit *": "deny",
          "git push *": "deny",
          "git reset *": "deny",
          "git clean *": "deny",
          "sudo *": "deny",
          "rm -rf *": "deny"
        },
        "task": "deny",
        "webfetch": "ask",
        "websearch": "ask",
        "external_directory": "ask",
        "doom_loop": "ask"
      }
    },
    "repair-worker": {
      "description": "Model-agnostic repair and validation worker. Use for bug reproduction/root-cause fixes, test writing or repair, lint/type/build/CI failures, and smallest-safe correction loops after implementation.",
      "mode": "subagent",
      "model": "openrouter/minimax/minimax-m3",
      "temperature": 0.1,
      "prompt": "{file:./prompts/repair-worker.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "allow",
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "npm run lint": "allow",
          "npm run lint *": "allow",
          "npm run typecheck": "allow",
          "npm run typecheck *": "allow",
          "npm run test": "allow",
          "npm run test *": "allow",
          "npm run test:coverage": "allow",
          "npm run test:coverage *": "allow",
          "npm run test:perf": "allow",
          "npm run test:perf *": "allow",
          "npm run css:audit": "allow",
          "npm run css:audit *": "allow",
          "npm run css:audit:strict": "allow",
          "npm run css:audit:strict *": "allow",
          "npm run build": "allow",
          "npm run build *": "allow",
          "npm run check": "allow",
          "npm run check *": "allow",
          "git add *": "ask",
          "git commit *": "deny",
          "git push *": "deny",
          "git reset *": "deny",
          "git clean *": "deny",
          "sudo *": "deny",
          "rm -rf *": "deny"
        },
        "task": "deny",
        "webfetch": "ask",
        "websearch": "ask",
        "external_directory": "ask",
        "doom_loop": "ask"
      }
    },
    "docs-maintainer": {
      "description": "Model-agnostic documentation and research-maintenance worker. Use for README updates, durable Info/ research notes, architecture docs, usage docs, examples, and documentation follow-up after relevant repo changes.",
      "mode": "subagent",
      "model": "openrouter/moonshotai/kimi-k2.6",
      "temperature": 0.1,
      "prompt": "{file:./prompts/docs-maintainer.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "allow",
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git add *": "ask",
          "git commit *": "deny",
          "git push *": "deny",
          "git reset *": "deny",
          "git clean *": "deny",
          "sudo *": "deny",
          "rm -rf *": "deny"
        },
        "task": "deny",
        "webfetch": "ask",
        "websearch": "ask",
        "external_directory": "ask",
        "doom_loop": "ask"
      }
    },
    "code-reviewer": {
      "description": "Optional costly independent read-only review agent. Use only for high-risk diffs, large changes, security/auth/data/payment/migration work, public API changes, or when the user explicitly asks for independent review.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "temperature": 0.1,
      "prompt": "{file:./prompts/code-reviewer.md}",
      "options": {
        "reasoningEffort": "medium",
        "textVerbosity": "low",
        "reasoningSummary": "auto",
        "include": ["reasoning.encrypted_content"]
      },
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow"
        },
        "task": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "external_directory": "ask",
        "doom_loop": "ask"
      }
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git reset *": "deny",
      "git clean *": "deny",
      "git checkout *": "ask",
      "git switch *": "ask",
      "git restore *": "ask",
      "rm *": "ask",
      "sudo *": "ask"
    }
  }
}
